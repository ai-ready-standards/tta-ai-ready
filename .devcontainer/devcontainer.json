{
  "name": "TTA AI-Ready Standards",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "stardog-union.stardog-rdf-grammars"
      ],
      "settings": {
        "files.associations": {
          "*.jsonld": "json",
          "*.ttl": "turtle"
        },
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "postCreateCommand": "pip install -e tools/validator/ && echo '✅ tta-validator 설치 완료. 실행: tta-validator standards/P-01-research-data/examples/valid/'",

  "remoteUser": "vscode"
}
