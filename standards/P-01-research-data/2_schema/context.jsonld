{
  "@context": {
    "@version": 1.1,
    "@base": "https://standard.tta.or.kr/0976/",

    "//": "============================================================",
    "//": "TTAK.KO-10.0976 AI-Ready Application Profile — JSON-LD Context",
    "//": "Version: 1.0.0 (2026-05-04)",
    "//": "TTA-AP namespace: https://standard.tta.or.kr/ai-ready/profile#",
    "//": "============================================================",

    "//": "--- 외부 어휘 prefix (5종 핵심 + 5종 보조) ---",
    "ttaap": "https://standard.tta.or.kr/ai-ready/profile#",
    "tta0976": "https://standard.tta.or.kr/0976#",
    "tta0976cv": "https://standard.tta.or.kr/0976/cv#",
    "dcterms": "http://purl.org/dc/terms/",
    "dctype": "http://purl.org/dc/dcmitype/",
    "datacite": "http://datacite.org/schema/kernel-4#",
    "re3data": "https://www.re3data.org/schema#",
    "dcat": "http://www.w3.org/ns/dcat#",
    "schema": "https://schema.org/",
    "prov": "http://www.w3.org/ns/prov#",
    "dqv": "http://www.w3.org/ns/dqv#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "vcard": "http://www.w3.org/2006/vcard/ns#",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",

    "//": "============================================================",
    "//": "Repository 계층 (R1-R21, 26 elements)",
    "//": "============================================================",

    "Repository": "ttaap:Repository",
    "RepositoryUrl": {"@id": "dcat:landingPage", "@type": "@id"},
    "RepositoryIdentifier": {"@id": "dcterms:identifier", "@type": "xsd:string"},
    "RepositoryIdentifierType": {"@id": "datacite:identifierType", "@type": "xsd:string"},
    "RepositoryName": {"@id": "dcterms:title", "@container": "@language"},
    "RepositoryNameType": {"@id": "datacite:titleType", "@type": "xsd:string"},
    "RepositoryType": {"@id": "dcterms:type", "@type": "xsd:string"},
    "RepositoryLanguage": {"@id": "dcterms:language", "@type": "xsd:string"},
    "RepositorySubject": "dcterms:subject",
    "RepositoryDescription": {"@id": "dcterms:description", "@container": "@language"},
    "InstitutionName": {"@id": "re3data:institutionName", "@container": "@language"},
    "InstitutionCountry": {"@id": "re3data:institutionCountry", "@type": "xsd:string"},
    "DatabaseAccessType": {"@id": "re3data:databaseAccessType", "@type": "xsd:string"},
    "DataAccessType": {"@id": "re3data:dataAccessType", "@type": "xsd:string"},
    "DataLicenseName": {"@id": "re3data:dataLicenseName", "@type": "xsd:string"},
    "DataLicenseUrl": {"@id": "re3data:dataLicenseURL", "@type": "@id"},
    "DataUpload": {"@id": "re3data:dataUpload", "@type": "xsd:string"},
    "Versioning": {"@id": "re3data:versioning", "@type": "xsd:string"},
    "EnhancedPublication": {"@id": "re3data:enhancedPublication", "@type": "xsd:string"},
    "QualityManagement": {"@id": "re3data:qualityManagement", "@type": "xsd:string"},
    "ResponsibilityType": {"@id": "re3data:responsibilityType", "@type": "xsd:string"},
    "InstitutionContact": {"@id": "dcat:contactPoint"},
    "RepositoryContact": {"@id": "dcat:contactPoint"},

    "//": "============================================================",
    "//": "Collection 계층 (C1-C12, 18 elements)",
    "//": "============================================================",

    "Collection": "dctype:Collection",
    "CollectionIdentifier": {"@id": "dcterms:identifier", "@type": "xsd:string"},
    "CollectionIdentifierType": {"@id": "datacite:identifierType", "@type": "xsd:string"},
    "CollectionTitle": {"@id": "dcterms:title", "@container": "@language"},
    "CollectionTitleType": {"@id": "datacite:titleType", "@type": "xsd:string"},
    "CollectionDate": {"@id": "dcterms:date", "@type": "xsd:date"},
    "CollectionDateType": {"@id": "ttaap:CollectionDateType", "@type": "xsd:string"},
    "CollectionDescription": {"@id": "dcterms:description", "@container": "@language"},
    "CollectionSubject": "dcterms:subject",
    "CollectionSubjectScheme": {"@id": "re3data:subjectScheme", "@type": "xsd:string"},
    "CollectionSubjectID": {"@id": "re3data:subjectID", "@type": "xsd:string"},
    "CollectionSubjectName": {"@id": "re3data:subjectName", "@type": "xsd:string"},
    "CollectionCreator": {"@id": "dcterms:creator"},
    "CollectionContact": {"@id": "dcat:contactPoint"},
    "CollectionRights": "dcterms:rights",
    "CollectionKeyword": {"@id": "dcat:keyword", "@type": "xsd:string"},
    "CollectionAccessType": {"@id": "re3data:dataAccessType", "@type": "xsd:string"},
    "CollectionAccessRestriction": {"@id": "re3data:dataAccessRestriction", "@type": "xsd:string"},

    "//": "============================================================",
    "//": "Dataset 계층 (D1-D15, 22 elements)",
    "//": "============================================================",

    "Dataset": "dcat:Dataset",
    "DatasetIdentifier": {"@id": "dcterms:identifier", "@type": "xsd:string"},
    "DatasetIdentifierType": {"@id": "datacite:identifierType", "@type": "xsd:string"},
    "DatasetTitle": {"@id": "dcterms:title", "@container": "@language"},
    "DatasetTitleType": {"@id": "datacite:titleType", "@type": "xsd:string"},
    "DatasetCreator": {"@id": "dcterms:creator"},
    "DatasetPublisher": {"@id": "dcterms:publisher"},
    "PublicationYear": {"@id": "datacite:publicationYear", "@type": "xsd:gYear"},
    "DatasetDate": {"@id": "dcterms:date", "@type": "xsd:date"},
    "DatasetDateType": {"@id": "datacite:dateType", "@type": "xsd:string"},
    "DatasetDescription": {"@id": "dcterms:description", "@container": "@language"},
    "DatasetSubject": "dcterms:subject",
    "DatasetSubjectScheme": {"@id": "re3data:subjectScheme", "@type": "xsd:string"},
    "DatasetSubjectID": {"@id": "re3data:subjectID", "@type": "xsd:string"},
    "DatasetSubjectName": {"@id": "re3data:subjectName", "@type": "xsd:string"},
    "DatasetContributor": {"@id": "datacite:contributor"},
    "DatasetContributorType": {"@id": "datacite:contributorType", "@type": "xsd:string"},
    "DatasetContact": {"@id": "dcat:contactPoint"},
    "DatasetRights": "datacite:rights",
    "DatasetKeyword": {"@id": "dcat:keyword", "@type": "xsd:string"},
    "DatasetAccessType": {"@id": "re3data:dataAccessType", "@type": "xsd:string"},
    "DatasetAccessRestriction": {"@id": "re3data:dataAccessRestriction", "@type": "xsd:string"},

    "//": "============================================================",
    "//": "File 계층 (F1-F19, 27 elements)",
    "//": "============================================================",

    "File": "dcat:Distribution",
    "FileIdentifier": {"@id": "dcterms:identifier", "@type": "xsd:string"},
    "FileIdentifierType": {"@id": "datacite:identifierType", "@type": "xsd:string"},
    "FileTitle": {"@id": "dcterms:title", "@container": "@language"},
    "FileTitleType": {"@id": "datacite:titleType", "@type": "xsd:string"},
    "FileCreator": {"@id": "dcterms:creator"},
    "FilePublisher": {"@id": "dcterms:publisher"},
    "FilePublicationYear": {"@id": "datacite:publicationYear", "@type": "xsd:gYear"},
    "FileContributor": {"@id": "datacite:contributor"},
    "FileContributorType": {"@id": "datacite:contributorType", "@type": "xsd:string"},
    "FileDate": {"@id": "dcterms:date", "@type": "xsd:date"},
    "FileDateType": {"@id": "datacite:dateType", "@type": "xsd:string"},
    "FileDescription": {"@id": "dcterms:description", "@container": "@language"},
    "FileSubject": "dcterms:subject",
    "FileSubjectScheme": {"@id": "re3data:subjectScheme", "@type": "xsd:string"},
    "FileSubjectID": {"@id": "re3data:subjectID", "@type": "xsd:string"},
    "FileSubjectName": {"@id": "re3data:subjectName", "@type": "xsd:string"},
    "FileContact": {"@id": "dcat:contactPoint"},
    "FileRights": "datacite:rights",
    "FileKeyword": {"@id": "dcat:keyword", "@type": "xsd:string"},
    "FileAccessType": {"@id": "re3data:dataAccessType", "@type": "xsd:string"},
    "FileAccessRestriction": {"@id": "re3data:dataAccessRestriction", "@type": "xsd:string"},
    "FileCoverage": "dcterms:coverage",
    "FileType": {"@id": "dcterms:type", "@type": "@id"},
    "FileFormat": {"@id": "dcterms:format", "@type": "xsd:string"},
    "FileSize": {"@id": "dcterms:extent", "@type": "xsd:nonNegativeInteger"},
    "FileUnit": {"@id": "schema:unitText", "@type": "xsd:string"},

    "//": "============================================================",
    "//": "구성요소 #5 (출처·계보) — 조건부 활성 (Decision-Q3/Q7)",
    "//": "============================================================",

    "wasGeneratedBy": "prov:wasGeneratedBy",
    "wasRevisionOf": "prov:wasRevisionOf",
    "wasInvalidatedBy": "prov:wasInvalidatedBy",
    "generatedAtTime": {"@id": "prov:generatedAtTime", "@type": "xsd:dateTime"},
    "invalidatedAtTime": {"@id": "prov:invalidatedAtTime", "@type": "xsd:dateTime"},
    "hadRole": "prov:hadRole",

    "//": "============================================================",
    "//": "구성요소 #6 (품질) — DQV Boolean Activation Slot (Decision-Q4)",
    "//": "============================================================",

    "hasQualityMeasurement": "dqv:hasQualityMeasurement",
    "hasQualityMetadata": "dqv:hasQualityMetadata",
    "isMeasurementOf": "dqv:isMeasurementOf",

    "//": "============================================================",
    "//": "Subject Class — SKOS Concept 패턴 (Decision-2)",
    "//": "============================================================",

    "Concept": "skos:Concept",
    "ConceptScheme": "skos:ConceptScheme",
    "inScheme": "skos:inScheme",
    "notation": "skos:notation",
    "prefLabel": {"@id": "skos:prefLabel", "@container": "@language"}
  }
}
