{
  "@context": {
    "@version": 1.1,
    "@protected": true,

    "tta": "https://standards.tta.or.kr/ai-ready/research-data/v1#",
    "dcat": "http://www.w3.org/ns/dcat#",
    "dct": "http://purl.org/dc/terms/",
    "dcmitype": "http://purl.org/dc/dcmitype/",
    "datacite": "http://purl.org/spar/datacite/",
    "prov": "http://www.w3.org/ns/prov#",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "duo": "http://purl.obolibrary.org/obo/DUO_",
    "cc": "http://creativecommons.org/ns#",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Collection": "dcat:Catalog",
    "Dataset": "dcat:Dataset",
    "File": "dcat:Distribution",
    "Repository": "dcat:DataService",

    "id": "@id",
    "type": "@type",
    "lang": "@language",

    "identifier": "dct:identifier",
    "identifierType": "tta:identifierType",
    "title": {"@id": "dct:title", "@container": "@language"},
    "titleType": "tta:titleType",
    "publicationYear": {"@id": "dct:issued", "@type": "xsd:gYear"},
    "date": {"@id": "dct:date", "@type": "xsd:date"},
    "dateType": "tta:dateType",
    "description": {"@id": "dct:description", "@container": "@language"},

    "subject": {"@id": "dct:subject", "@type": "@id"},
    "subjectScheme": "tta:subjectScheme",
    "subjectId": "tta:subjectId",
    "subjectName": {"@id": "skos:prefLabel", "@container": "@language"},

    "creator": {"@id": "dct:creator"},
    "publisher": {"@id": "dct:publisher"},
    "contributor": {"@id": "dct:contributor"},
    "contributorType": "tta:contributorType",
    "contact": "tta:contact",

    "rights": "dct:rights",
    "license": {"@id": "dct:license", "@type": "@id"},
    "keyword": "dcat:keyword",
    "accessType": "tta:accessType",
    "accessRestriction": "tta:accessRestriction",

    "coverage": "dct:coverage",
    "format": "dct:format",
    "size": {"@id": "dcat:byteSize", "@type": "xsd:nonNegativeInteger"},
    "sizeUnit": "tta:sizeUnit",

    "distribution": {"@id": "dcat:distribution", "@type": "@id"},
    "downloadURL": {"@id": "dcat:downloadURL", "@type": "@id"},
    "mediaType": "dcat:mediaType",

    "repositoryUrl": {"@id": "dcat:endpointURL", "@type": "@id"},
    "repositoryName": {"@id": "dct:title", "@container": "@language"},
    "repositoryNameType": "tta:titleType",
    "repositoryLanguage": "dct:language",
    "institutionName": "schema:legalName",
    "institutionCountry": "schema:addressCountry",
    "institutionContact": "schema:contactPoint",
    "repositoryContact": "tta:repositoryContact",
    "databaseAccessType": "tta:databaseAccessType",
    "dataAccessType": "tta:dataAccessType",
    "dataLicenseName": "tta:dataLicenseName",
    "dataLicenseUrl": {"@id": "dct:license", "@type": "@id"},
    "dataUpload": "tta:dataUpload",
    "versioning": "tta:versioning",
    "enhancedPublication": "tta:enhancedPublication",
    "qualityManagement": "tta:qualityManagement",
    "responsibilityType": "tta:responsibilityType",

    "wasGeneratedBy": {"@id": "prov:wasGeneratedBy", "@type": "@id"},
    "wasDerivedFrom": {"@id": "prov:wasDerivedFrom", "@type": "@id"},
    "wasAttributedTo": {"@id": "prov:wasAttributedTo", "@type": "@id"},

    "Person": "schema:Person",
    "Organization": "schema:Organization",
    "name": "schema:name",
    "email": "schema:email",
    "url": {"@id": "schema:url", "@type": "@id"}
  }
}
