# Dataset SHACL shapes — TTAK.KO-10.0976 §6.3 (D1~D15)
#
# Severity 매핑:
#   M (Mandatory)   → sh:Violation
#   R (Recommended) → sh:Warning
#   O (Optional)    → 미선언 (정보성)

@prefix sh:        <http://www.w3.org/ns/shacl#> .
@prefix dcat:      <http://www.w3.org/ns/dcat#> .
@prefix dct:       <http://purl.org/dc/terms/> .
@prefix tta:       <https://standards.tta.or.kr/ai-ready/research-data/v1#> .
@prefix skos:      <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:       <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .

tta:DatasetShape
    a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    rdfs:label "TTAK.KO-10.0976 Dataset Shape (D1~D15)" ;

    # D2 Identifier (M)
    sh:property [
        sh:path dct:identifier ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "[D2] Dataset must have at least one dct:identifier" ;
    ] ;

    # D2.1 IdentifierType (M, CVP)
    sh:property [
        sh:path tta:identifierType ;
        sh:minCount 1 ;
        sh:in ( "ARK" "arXiv" "bibcode" "DOI" "EAN13" "EISSN" "Handle"
                "ISBN" "ISSN" "ISTC" "LISSN" "LSID" "PMID" "PURL"
                "UPC" "URL" "URN" "URI" "UCI" ) ;
        sh:severity sh:Violation ;
        sh:message "[D2.1] tta:identifierType is mandatory and must be one of the IdentifierType controlled vocabulary values" ;
    ] ;

    # D3 Title (M)
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "[D3] Dataset must have at least one dct:title" ;
    ] ;

    # D3.1 TitleType (O)
    sh:property [
        sh:path tta:titleType ;
        sh:in ( "AlternativeTitle" "Subtitle" "TranslatedTitle" "other" ) ;
        sh:severity sh:Info ;
        sh:message "[D3.1] tta:titleType (if present) must be one of the TitleType controlled vocabulary values" ;
    ] ;

    # D4 Creator (M)
    sh:property [
        sh:path dct:creator ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "[D4] Dataset must have at least one dct:creator" ;
    ] ;

    # D5 Publisher (M)
    sh:property [
        sh:path dct:publisher ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "[D5] Dataset must have at least one dct:publisher" ;
    ] ;

    # D6 PublicationYear (M, SEP — xsd:gYear)
    sh:property [
        sh:path dct:issued ;
        sh:minCount 1 ;
        sh:datatype xsd:gYear ;
        sh:severity sh:Violation ;
        sh:message "[D6] Dataset must have dct:issued (publicationYear) as xsd:gYear" ;
    ] ;

    # D7 Date (R, SEP — xsd:date)
    sh:property [
        sh:path dct:date ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Warning ;
        sh:message "[D7] Dataset is recommended to have dct:date (xsd:date)" ;
    ] ;

    # D7.1 DateType (M when D7 is present)
    sh:property [
        sh:path tta:dateType ;
        sh:in ( "Accepted" "Available" "Copyrighted" "Collected" "Created"
                "Issued" "Submitted" "Updated" "Valid" ) ;
        sh:severity sh:Warning ;
        sh:message "[D7.1] tta:dateType (when date present) must be from DatasetDateType controlled vocabulary" ;
    ] ;

    # D8 Description (R)
    sh:property [
        sh:path dct:description ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "[D8] Dataset is recommended to have dct:description" ;
    ] ;

    # D9 Subject (R)
    sh:property [
        sh:path dct:subject ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "[D9] Dataset is recommended to have dct:subject" ;
    ] ;

    # D10 Contributor (R)
    sh:property [
        sh:path dct:contributor ;
        sh:severity sh:Info ;
        sh:message "[D10] Dataset may have dct:contributor (recommended for collaborative datasets)" ;
    ] ;

    # D10.1 ContributorType (M when D10 present)
    sh:property [
        sh:path tta:contributorType ;
        sh:in ( "ContactPerson" "DataCollector" "DataCurator" "DataManager"
                "Distributor" "Editor" "Funder" "HostingInstitution"
                "Producer" "ProjectLeader" "ProjectManager" "ProjectMember"
                "RegistrationAgency" "RegistrationAuthority" "RelatedPerson"
                "Researcher" "ResearchGroup" "RightsHolder" "Sponsor"
                "Supervisor" "WorkPackageLeader" "Other" ) ;
        sh:severity sh:Warning ;
        sh:message "[D10.1] tta:contributorType (when contributor present) must be from ContributorType controlled vocabulary" ;
    ] ;

    # D14 AccessType (O, CVP)
    sh:property [
        sh:path tta:accessType ;
        sh:in ( "open" "embargoed" "restricted" "closed" ) ;
        sh:severity sh:Info ;
        sh:message "[D14] tta:accessType (if present) must be one of: open, embargoed, restricted, closed" ;
    ] ;

    # D15 AccessRestriction (O, CVP)
    sh:property [
        sh:path tta:accessRestriction ;
        sh:in ( "feeRequired" "registration" "institutional membership"
                "non-registration" "free" "other" ) ;
        sh:severity sh:Info ;
        sh:message "[D15] tta:accessRestriction (if present) must be from CollectionAccessRestrictionType vocabulary" ;
    ] .


# Subject sub-shape (D9, D9.1~D9.3)
tta:SubjectShape
    a sh:NodeShape ;
    sh:targetSubjectsOf dct:subject ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 0 ;
        sh:severity sh:Info ;
    ] .
